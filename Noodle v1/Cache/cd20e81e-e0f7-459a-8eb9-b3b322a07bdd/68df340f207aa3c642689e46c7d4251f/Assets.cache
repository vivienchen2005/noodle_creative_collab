    - // @input int _renderOrder
    - "// @input vec2 _size = {10,10}"
    - '// @input string _style = "default" {"widget":"combobox", "values":[{"label":"Default", "value":"default"}, {"label":"Dark", "value":"dark"}, {"label":"Simple", "value":"simple"}]}'
